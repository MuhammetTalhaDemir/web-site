<button id="themeToggle" class="theme-btn" aria-label="Tema Değiştir" type="button">
  <svg class="sun" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"/><path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/></svg>
  <svg class="moon" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
</button>

<style>
  .theme-btn {
    background: transparent;
    border: none;
    cursor: pointer;
    color: rgb(var(--black));
    padding: 0;
    margin-left: 1rem; /* Sosyal ikonlardan biraz ayırır */
    display: flex;
    align-items: center;
  }
  
  /* Görünürlük Ayarı: Sadece biri görünecek */
  :root.dark .sun { display: block; }
  :root.dark .moon { display: none; }
  :root:not(.dark) .sun { display: none; }
  :root:not(.dark) .moon { display: block; }

  svg {
    width: 20px;
    height: 20px;
    transition: transform 0.2s ease;
  }
  .theme-btn:hover svg {
    transform: scale(1.1);
    color: var(--accent);
  }
</style>

<script is:inline>
  function initTheme() {
    const toggle = document.querySelector('#themeToggle');
    if (toggle) {
      console.log("Buton yakalandı!");
      toggle.addEventListener('click', () => {
        const isDark = document.documentElement.classList.toggle('dark');
        localStorage.setItem('theme', isDark ? 'dark' : 'light');
      });
    }
  }

  // Astro için 3 koldan saldırı
  initTheme();
  document.addEventListener('astro:after-swap', initTheme);
  document.addEventListener('astro:page-load', initTheme);
</script>