<button id="themeToggle" class="theme-btn" aria-label="Tema Değiştir">
    <svg class="sun-icon" ...>/* Güneş SVG */</svg>
    <svg class="moon-icon" ...>/* Ay SVG */</svg>
</button>

<style>
    .theme-btn {
        background: transparent;
        border: none;
        padding: 8px;
        cursor: pointer;
        display: flex;
        align-items: center;
        color: rgb(var(--black)); /* İkon rengini değişkenden alır */
    }

    /* İkonların görünürlüğü */
    :root.dark .sun-icon { display: block; }
    :root.dark .moon-icon { display: none; }
    :root:not(.dark) .sun-icon { display: none; }
    :root:not(.dark) .moon-icon { display: block; }

    /* SVG'lerin boyutunu sabitle */
    svg {
        width: 24px;
        height: 24px;
        fill: currentColor;
    }
</style>