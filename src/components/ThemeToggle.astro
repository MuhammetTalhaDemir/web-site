<button id="themeToggle" class="theme-button" aria-label="Tema Değiştir" type="button">
    <svg class="sun" ...>...</svg>
    <svg class="moon" ...>...</svg>
</button>

<script is:inline>
  const toggleTheme = () => {
    const html = document.documentElement;
    const isDark = html.classList.toggle('dark');
    localStorage.setItem('theme', isDark ? 'dark' : 'light');
    
    // ZORLA RENK DEĞİŞTİRME (CSS Değişkenlerini beklemiyoruz)
    if (isDark) {
      html.style.backgroundColor = "#1f232d";
      document.body.style.backgroundColor = "#1f232d";
      document.body.style.color = "#c8d2e6";
    } else {
      html.style.backgroundColor = "#e5e9f0";
      document.body.style.backgroundColor = "#e5e9f0";
      document.body.style.color = "#222939";
    }
    console.log("Mühendislik Raporu: Tema zorla değiştirildi. Yeni:", isDark ? "Dark" : "Light");
  };

  document.getElementById('themeToggle').onclick = toggleTheme;
  document.addEventListener('astro:after-swap', () => {
    document.getElementById('themeToggle').onclick = toggleTheme;
  });
</script>