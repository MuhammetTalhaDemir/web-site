<button id="themeToggle" aria-label="Tema Değiştir">
  <svg id="sun-icon" ...>...</svg>
  <svg id="moon-icon" ...>...</svg>
</button>

<script is:inline>
  // Bu fonksiyonu bir değişkene atayalım ki tekrar tekrar çağırabilelim
  const setupToggle = () => {
    const button = document.getElementById('themeToggle');
    if (!button) return; // Buton yoksa hata verme, çık

    button.addEventListener('click', () => {
      const isDark = document.documentElement.classList.contains('dark');
      const newTheme = isDark ? 'light' : 'dark';
      
      // 1. Görsel değişimi yap
      if (newTheme === 'dark') {
        document.documentElement.classList.add('dark');
      } else {
        document.documentElement.classList.remove('dark');
      }
      
      // 2. Hafızaya kaydet
      localStorage.setItem('theme', newTheme);
    });
  };

  // Sayfa ilk yüklendiğinde çalıştır
  setupToggle();

  // Astro sayfa geçişlerinde (eğer View Transitions kullanıyorsan) tekrar çalıştır
  document.addEventListener('astro:after-swap', setupToggle);
</script>